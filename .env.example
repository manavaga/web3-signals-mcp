# Database (omit for SQLite)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# x402 payments (omit to disable)
# PAY_TO=0xYourWalletAddress
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=
# SIGNAL_PRICE_USDC=0.001

# Auth
# ADMIN_TOKEN=your-admin-token
# INTERNAL_API_KEY=your-internal-key

# Scheduling
# ORCHESTRATOR_INTERVAL_SEC=900
# SIGNAL_CADENCE_HOURS=12

# Logging
# LOG_LEVEL=INFO
